# Local directory for Terraform plugins and cache
.terraform/

# Local lock files containing provider version constraints
.terraform.lock.hcl

# State files created during deployments
*.tfstate
*.tfstate.backup

# Actual variables files that might contain local API secrets or settings
*.tfvars

# Log files
*.log
crash.log

# Local SSH Keys
terraforge-key
terraforge-key.pub
terraforge-key-pem
terraforge-key-pem.pub
